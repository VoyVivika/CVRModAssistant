{
  "name": "cvr-mod-assistant",
  "version": "1.0.4",
  "description": "Mod manager for ChilloutVR",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "node_modules\\electron\\dist\\electron.exe . --inspect",
    "build": "node node_modules/electron-builder/cli.js --win",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "build": {
    "appId": "com.lenserror.cvr-mod-assistant",
    "productName": "CVR Mod Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "dll-parser.js",
      "renderer/**/*"
    ],
    "win": {
      "icon": "renderer/assets/icons/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "CVRModAssistant_Setup.${ext}",
      "perMachine": false,
      "installerHeaderIcon": "renderer/assets/icons/icon.ico"
    },
    "portable": {
      "artifactName": "CVRModAssistant.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "LensError",
      "repo": "CVRModAssistant"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LensError/CVRModAssistant.git"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "v8-compile-cache": "^2.3.0",
    "winreg": "^1.2.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^34.0.0"
  },
  "author": "LensError",
  "license": "MIT"
}
